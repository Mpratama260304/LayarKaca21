# Origin site to mirror (no trailing slash)
ORIGIN_URL=http://168.144.38.21

# Port the server listens on. Railway/Render set this automatically.
PORT=8080

# Your single public domain. Every other host (Railway subdomain, IP, www)
# gets 301-redirected here so Google indexes ONE canonical domain.
# Leave empty to derive the domain dynamically from the incoming Host header.
CANONICAL_HOST=yourdomain.com

# Force https in all rewritten URLs/canonicals.
# Leave false: the protocol is auto-detected from x-forwarded-proto, which
# Railway/Render/most hosts set to https automatically. Only set true if your
# platform does NOT send x-forwarded-proto but still serves https.
FORCE_HTTPS=false

# Remove ad / popunder / tracker scripts (recommended: true)
REMOVE_ADS=true

# Keep Google Tag Manager / Analytics (default false = also removed)
KEEP_ANALYTICS=false

# Extra ad domains to block, comma separated (optional)
EXTRA_AD_DOMAINS=

# Video player domains that must NEVER be blocked, comma separated
PLAYER_DOMAINS=bysetayico.com
